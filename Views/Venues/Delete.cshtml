@model EventEase.Models.Venue

@{
    ViewData["Title"] = "Delete";
}

<div class="row justify-content-center">
    <div class="col-md-5">

        <div class="card shadow-sm border-0">
            <div class="card-body p-4">

                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h4 class="fw-bold text-danger mb-0">Delete Venue</h4>

                    <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
                        ← Back
                    </a>
                </div>

                <p class="text-muted mb-4">
                    Are you sure you want to delete this venue?
                </p>

                <div class="mb-3">
                    <strong>@Model.VenueName</strong>
                </div>

                <p class="text-muted mb-1">@Model.Location</p>
                <p class="mb-3">Capacity: @Model.Capacity</p>

                <img src="@(string.IsNullOrEmpty(Model.ImageUrl)
                                                 ? "https://via.placeholder.com/300x180"
                                                 : Model.ImageUrl)"
                     class="img-fluid rounded mb-4"
                     style="height:150px; object-fit:cover;" />

                <form asp-action="Delete">

                    <input type="hidden" asp-for="VenueId" />

                    <div class="d-flex justify-content-between">

                        <a asp-action="Index" class="btn btn-outline-secondary">
                            Cancel
                        </a>

                        <input type="submit" value="Delete" class="btn btn-danger" />

                    </div>

                </form>

            </div>
        </div>

    </div>
</div>