@{
    ViewData["Title"] = "Venues";
}

<div class="d-flex justify-content-between mb-4">
    <h2>Venues</h2>

    <button class="btn btn-success" data-bs-toggle="modal" data-bs-target="#addVenueModal">
        + Add Venue
    </button>
</div>

<div class="row g-4">

    <div class="col-md-3">
        <div class="card shadow-sm">

            <img src="https://images.unsplash.com/photo-1519167758481-83f550bb49b3"
                 class="card-img-top"
                 style="height:180px; object-fit:cover;" />

            <div class="card-body">

                <h5 class="card-title">Grand Ballroom</h5>

                <p class="text-muted">123 Main St, Downtown</p>

                <p>Capacity: 500</p>

                <div class="d-flex gap-2">

                    <button class="btn btn-outline-primary btn-sm">
                        Edit
                    </button>

                    <button class="btn btn-outline-danger btn-sm">
                        Delete
                    </button>

                </div>

            </div>

        </div>
    </div>

</div>

<div class="modal fade" id="addVenueModal">

    <div class="modal-dialog">
        <div class="modal-content">

            <div class="modal-header">
                <h5>Add Venue</h5>
                <button class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">

                <form>

                    <div class="mb-3">
                        <label>Venue Name</label>
                        <input class="form-control" />
                    </div>

                    <div class="mb-3">
                        <label>Location</label>
                        <input class="form-control" />
                    </div>

                    <div class="mb-3">
                        <label>Capacity</label>
                        <input type="number" class="form-control" />
                    </div>

                    <div class="mb-3">
                        <label>Image URL</label>
                        <input class="form-control" />
                    </div>

                    <button class="btn btn-success">
                        Save
                    </button>

                </form>

            </div>

        </div>
    </div>

</div>