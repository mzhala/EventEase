@model IEnumerable<EventEase.Models.Venue>

@{
    ViewData["Title"] = "Venues";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold">Venues</h2>

    <a asp-action="Create" class="btn btn-success">
        Add Venue
    </a>
</div>

<form method="get" id="searchForm" class="mb-3">
    <input type="text"
           id="searchInput"
           name="searchString"
           value="@Context.Request.Query["searchString"]"
           class="form-control"
           placeholder="Search venues..." />
</form>

<div class="row g-4">

    @foreach (var item in Model)
    {
        <div class="col-md-3">

            <div class="card shadow-sm h-100">

                <img src="@(string.IsNullOrEmpty(item.ImageUrl)
                                             ? "https://via.placeholder.com/300x180"
                                             : item.ImageUrl)"
                 class="card-img-top"
                 style="height:180px; object-fit:cover;" />

                <div class="card-body d-flex flex-column">

                    <h5 class="card-title">@item.VenueName</h5>

                    <p class="text-muted mb-1">@item.Location</p>

                    <p class="mb-3">Capacity: @item.Capacity</p>

                    <div class="mt-auto d-flex gap-2">

                        <a asp-action="Edit" asp-route-id="@item.VenueId"
                           class="btn btn-outline-primary btn-sm">
                            Edit
                        </a>

                        <a asp-action="Delete" asp-route-id="@item.VenueId"
                           class="btn btn-outline-danger btn-sm">
                            Delete
                        </a>

                    </div>

                </div>

            </div>

        </div>
        }

</div>

@section Scripts {
    <script>
        let timeout = null;

        const input = document.getElementById("searchInput");

        if (input) {

            // Restore focus after page reload
            window.onload = function () {
                input.focus();

                // Move cursor to end
                const val = input.value;
                input.value = "";
                input.value = val;
            };

            input.addEventListener("keyup", function () {
                clearTimeout(timeout);

                timeout = setTimeout(() => {
                    document.getElementById("searchForm").submit();
                }, 500);
            });
        }
    </script>
}
