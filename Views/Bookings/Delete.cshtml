@model EventEase.Models.Booking

@{
    ViewData["Title"] = "Delete Booking";
}

<div class="row justify-content-center">
    <div class="col-md-5">

        <div class="card shadow-sm border-0">
            <div class="card-body p-4">

                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h4 class="fw-bold text-danger mb-0">Delete Booking</h4>

                    <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
                        ← Back
                    </a>
                </div>

                <p class="text-muted mb-4">
                    Are you sure you want to delete this booking?
                </p>

                <hr />

                <div class="mb-3">
                    <strong>Event:</strong>
                    <div class="text-muted">@Model.Event?.EventName</div>
                </div>

                <div class="mb-3">
                    <strong>Venue:</strong>
                    <div class="text-muted">@Model.Venue?.VenueName</div>
                </div>

                <div class="mb-4">
                    <strong>Booking Date:</strong>
                    <div class="text-muted">
                        @Model.BookingDate.ToString("dd MMM yyyy HH:mm")
                    </div>
                </div>

                <form asp-action="Delete">

                    <input type="hidden" asp-for="BookingId" />

                    <div class="d-flex justify-content-between">

                        <a asp-action="Index" class="btn btn-outline-secondary">
                            Cancel
                        </a>

                        <input type="submit" value="Delete" class="btn btn-danger" />

                    </div>

                </form>

            </div>
        </div>

    </div>
</div>