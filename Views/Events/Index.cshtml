@model IEnumerable<EventEase.Models.Event>

@{
    ViewData["Title"] = "Events";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold">Events</h2>

    <a asp-action="Create" class="btn btn-success">
        + Add Event
    </a>
</div>

<div class="card shadow-sm border-0">
    <div class="card-body p-0">

        <table class="table table-hover mb-0">

            <thead class="table-light">
                <tr>
                    <th>Event Name</th>
                    <th>Date</th>
                    <th>Venue</th>
                    <th>Description</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>

            <tbody>

                @foreach (var item in Model)
                {
                    <tr>
                        <td class="fw-semibold">
                            @item.EventName
                        </td>

                        <td>
                            @item.EventDate.ToString("dd MMM yyyy")
                        </td>

                        <td>
                            @item.Venue?.VenueName
                        </td>

                        <td class="text-muted">
                            @item.Description
                        </td>

                        <td class="text-end">

                            <a asp-action="Edit" asp-route-id="@item.EventId"
                               class="btn btn-outline-primary btn-sm">
                                Edit
                            </a>

                            <a asp-action="Delete" asp-route-id="@item.EventId"
                               class="btn btn-outline-danger btn-sm">
                                Delete
                            </a>

                        </td>
                    </tr>
                }

            </tbody>

        </table>

    </div>
</div>